<script>
// Function to generate avatar based on input ID
function generateDeterministicAvatar() {
  const input = document.getElementById('avatar-id-input');
  const avatarImg = document.getElementById('deterministic-avatar');
  const urlDisplay = document.getElementById('current-id-url');
  
  let id = input.value.trim();
  
  // Validate input - only allow numbers and letters, prevent empty
  if (id === '') {
    id = '42';
    input.value = '42';
  }
  
  // Sanitize - remove any special characters except alphanumeric and hyphen
  id = id.replace(/[^a-zA-Z0-9-]/g, '');
  
  if (id === '') {
    id = '42';
    input.value = '42';
  }
  
  // Update image source with new ID
  const timestamp = Date.now();
  const newSrc = `/api/avatars/${id}?t=${timestamp}`;
  avatarImg.src = newSrc;
  avatarImg.dataset.base = `/api/avatars/${id}`;
  
  // Update URL display
  urlDisplay.textContent = `/api/avatars/${id}`;
  
  // Add a little animation effect to show refresh
  avatarImg.classList.add('scale-110', 'rotate-3');
  setTimeout(() => {
    avatarImg.classList.remove('scale-110', 'rotate-3');
  }, 200);
}

// Handle Enter key in input
function handleIdInputKeyPress(event) {
  if (event.key === 'Enter') {
    generateDeterministicAvatar();
  }
}

// Set preset ID
function setPresetId(id) {
  const input = document.getElementById('avatar-id-input');
  input.value = id;
  generateDeterministicAvatar();
}

// Override the refreshSpecific function for deterministic card to use our custom logic
function refreshSpecific(btn) {
  // Check if this is the deterministic card
  const card = btn.closest('.group');
  if (card && card.querySelector('#deterministic-avatar')) {
    generateDeterministicAvatar();
  } else {
    // Original refresh logic for other cards
    const img = card.querySelector('img[data-base]') || card.querySelector('img[src*="/api/avatars"]');
    if (!img) return;
    
    let base = img.dataset.base || img.src.split('?')[0];
    if (!img.dataset.base) {
      if (img.src.includes('gender=boy')) base = '/api/avatars?gender=boy';
      else if (img.src.includes('gender=girl')) base = '/api/avatars?gender=girl';
      else if (img.src.match(/\/api\/avatars\/\d+/)) {
        let matches = img.src.match(/(\/api\/avatars\/\d+)/);
        base = matches ? matches[1] : '/api/avatars/42';
      } else base = '/api/avatars';
    }
    
    const ts = Date.now();
    img.src = base + (base.includes('?') ? '&t=' : '?t=') + ts;
    img.dataset.base = base;
  }
}

// Initialize input with current ID from URL on page load
document.addEventListener('DOMContentLoaded', function() {
  const avatarImg = document.getElementById('deterministic-avatar');
  const input = document.getElementById('avatar-id-input');
  const urlDisplay = document.getElementById('current-id-url');
  
  if (avatarImg && input && urlDisplay) {
    // Extract current ID from src
    const src = avatarImg.src;
    const match = src.match(/\/api\/avatars\/([^?]+)/);
    if (match && match[1]) {
      input.value = match[1];
      urlDisplay.textContent = `/api/avatars/${match[1]}`;
    }
  }
});
</script>

