<!-- ========== JAVASCRIPT (improved refresh + copy) ========== -->
<script>
  // universal refresh for hero images (works with any card)
  function refreshSpecific(btn) {
    const card = btn.closest('.group') || btn.closest('[class*="group"]');
    if (!card) return;
    const img = card.querySelector('img[data-base]') || card.querySelector('img[src*="/api/avatars"]');
    if (!img) return;
    // extract base url (remove timestamp if any)
    let base = img.dataset.base || img.src.split('?')[0];
    // preserve gender or id if present in original src (but we trust data-base as fallback)
    if (!img.dataset.base) {
      // guess base from src
      if (img.src.includes('gender=boy')) base = '/api/avatars?gender=boy';
      else if (img.src.includes('gender=girl')) base = '/api/avatars?gender=girl';
      else if (img.src.match(/\/api\/avatars\/\d+/)) {
        let matches = img.src.match(/(\/api\/avatars\/\d+)/);
        base = matches ? matches[1] : '/api/avatars/42';
      } else base = '/api/avatars';
    }
    const ts = Date.now();
    img.src = base + (base.includes('?') ? '&t=' : '?t=') + ts;
    // also update data-base for consistency
    img.dataset.base = base;
  }

  // make all avatar refresh buttons work (also the ones inside hero)
  document.querySelectorAll('.hero-avatar-refresh, .refresh-btn').forEach(btn => {
    btn.addEventListener('click', function(e) { e.preventDefault(); refreshSpecific(this); });
  });

  // copy to clipboard
  window.copyToClipboard = function(text) {
    navigator.clipboard?.writeText(text).then(() => {
      // optional tiny feedback (but we skip toast to keep clean)
    }).catch(() => alert('Press Ctrl+C to copy'));
  };

  // periodical shuffle for all previews (soft refresh, only if element visible)
  let refreshInterval = setInterval(() => {
    document.querySelectorAll('.hero-avatar-refresh').forEach(btn => {
      // only refresh if button is visible (reduce load)
      if (btn.offsetParent !== null) refreshSpecific(btn);
    });
  }, 8000); // every 8 seconds (smoother)

  // manual theme toggle (optional, but we keep from original with small fix)
  const toggle = document.getElementById('theme-toggle');
  if (toggle) {
    toggle.addEventListener('click', () => {
      document.documentElement.classList.toggle('dark');
      localStorage.theme = document.documentElement.classList.contains('dark') ? 'dark' : 'light';
    });
  }
  // apply dark as default (we are in dark already, but for completeness)
  if (localStorage.theme === 'light') document.documentElement.classList.remove('dark');
  else document.documentElement.classList.add('dark');

  // also add a small effect to copy buttons
  document.querySelectorAll('.code-copy-btn').forEach(btn => {
    btn.addEventListener('click', (e) => {
      e.stopPropagation();
      const codeEl = btn.closest('div')?.parentElement?.querySelector('code') || btn.parentElement?.nextElementSibling;
      if (codeEl) {
        let text = codeEl.innerText.replace(/<\/?[^>]+(>|$)/g, ""); // crude strip
        let match = text.match(/"([^"]+)"/);
        if (match && match[1]) copyToClipboard(match[1]);
        else copyToClipboard('/api/avatars');
      } else copyToClipboard('/api/avatars');
    });
  });
</script>

