<!DOCTYPE html>
<html lang="en" class="scroll-smooth">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>GenAvatar · instant avatars for developers</title>
  <meta name="description" content="Serverless‑ready avatar API: random, gender‑filtered or deterministic. One line of code, endless faces." />

  <!-- favicon (indigo smile) -->
  <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 100 100%22><rect width=%22100%22 height=%22100%22 rx=%2220%22 fill=%22%234f46e5%22/><circle cx=%2250%22 cy=%2235%22 r=%2218%22 fill=%22white%22/><circle cx=%2238%22 cy=%2230%22 r=%226%22 fill=%22%23c7d2fe%22/><circle cx=%2262%22 cy=%2230%22 r=%226%22 fill=%22%23c7d2fe%22/><path d=%22M35 55 Q50 70 65 55%22 stroke=%22white%22 stroke-width=%226%22 fill=%22none%22 stroke-linecap=%22round%22/></svg>" type="image/svg+xml" />

  <!-- Tailwind + custom config -->
  <script src="https://cdn.tailwindcss.com"></script>
  <script>
    tailwind.config = {
      darkMode: 'class',
      theme: {
        extend: {
          colors: { primary: '#6366f1', primarydark: '#4f46e5' },
          fontFamily: { sans: ['Inter', 'system-ui', 'sans-serif'], display: ['Space Grotesk', 'sans-serif'] },
          animation: { 'spin-slow': 'spin 8s linear infinite', 'pulse-slow': 'pulse 3s cubic-bezier(0.4, 0, 0.6, 1) infinite' }
        }
      }
    }
  </script>
  <!-- Google Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Space+Grotesk:wght@500;600;700&display=swap" rel="stylesheet">
  <!-- extra micro animations -->
  <style>
    * { scroll-behavior: smooth; }
    .glow-card {
      position: relative;
      transition: transform 0.25s ease, border-color 0.25s;
    }
    .glow-card::after {
      content: '';
      position: absolute;
      inset: -1px;
      border-radius: inherit;
      padding: 1px;
      background: radial-gradient(circle at 30% 30%, rgba(99,102,241,0.7), transparent 70%);
      -webkit-mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
      mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
      -webkit-mask-composite: xor;
      mask-composite: exclude;
      opacity: 0;
      transition: opacity 0.4s;
      pointer-events: none;
    }
    .glow-card:hover::after { opacity: 1; }
    .refresh-btn {
      backdrop-filter: blur(4px);
      transition: all 0.2s cubic-bezier(0.34, 1.56, 0.64, 1);
    }
    .refresh-btn:active { transform: scale(0.9) rotate(180deg); }
    .code-copy-btn { transition: all 0.15s; }
    .code-copy-btn:active { transform: scale(0.85); opacity: 0.7; }
    .gender-badge {
      transition: transform 0.2s ease;
    }
    .group:hover .gender-badge { transform: scale(1.1) rotate(6deg); }
  </style>
</head>
<body class="bg-slate-950 text-slate-100 antialiased selection:bg-indigo-500/30">

<!-- ========== STICKY HEADER ========== -->
<header class="sticky top-0 z-50 border-b border-slate-800/70 bg-slate-950/70 backdrop-blur-xl">
  <div class="max-w-7xl mx-auto px-6 py-4 flex items-center justify-between">
    <a href="/" class="text-2xl font-bold tracking-tight bg-gradient-to-r from-indigo-300 via-purple-300 to-indigo-400 bg-clip-text text-transparent hover:scale-[1.02] transition-transform">GenAvatar</a>
    <div class="flex items-center gap-3">
      <!-- GitHub button (improved) -->
      <a href="https://github.com/Adam99-dev/avatar-placeholder" target="_blank" rel="noopener noreferrer"
         class="group flex items-center gap-2 px-5 py-2.5 rounded-xl border border-indigo-700/50 bg-indigo-950/30 text-indigo-300 hover:text-indigo-100 hover:border-indigo-500 hover:bg-indigo-950/70 transition-all duration-300 font-medium shadow-sm hover:shadow-indigo-900/40">
        <svg class="w-5 h-5 transition-transform group-hover:scale-110 group-hover:rotate-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"/><path d="M9 18c-4.51 2-5-2-7-2"/></svg>
        <span class="hidden sm:inline">GitHub</span>
      </a>
      <!-- Live demo button with refresh icon -->
      <a href="#" onclick="document.querySelectorAll('.hero-avatar-refresh').forEach(btn => btn.click()); return false;"
         class="group flex items-center gap-2 px-5 py-2.5 rounded-xl border border-emerald-700/50 bg-emerald-950/30 text-emerald-300 hover:text-emerald-100 hover:border-emerald-500 hover:bg-emerald-950/70 transition-all font-medium">
        <svg class="w-5 h-5 transition-transform group-hover:scale-110 group-hover:rotate-12" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M4.9 19.1C1 15.2 1 8.8 4.9 4.9"/><path d="M7.8 16.2c-2.3-2.3-2.3-6.1 0-8.5"/><circle cx="12" cy="12" r="2"/><path d="M16.2 7.8c2.3 2.3 2.3 6.1 0 8.5"/><path d="M19.1 4.9C23 8.8 23 15.1 19.1 19"/></svg>
        <span class="hidden sm:inline">Live refresh</span>
      </a>
    </div>
  </div>
</header>

<main class="overflow-hidden">

<!-- ========== HERO CARDS SECTION (refined) ========== -->
<section class="relative py-16 md:py-24">
  <div class="absolute inset-0 bg-gradient-to-b from-indigo-950/20 via-transparent to-transparent pointer-events-none"></div>
  <div class="max-w-7xl mx-auto px-6 relative z-10">
    <!-- Eyebrow + headline -->
    <div class="text-center mb-16">
      <span class="inline-block px-4 py-1.5 rounded-full bg-indigo-950/40 border border-indigo-700/40 text-indigo-300 text-sm font-mono tracking-wider mb-5">⚡ API v1.0 · Serverless Ready</span>
      <h1 class="text-5xl md:text-7xl font-bold tracking-tight bg-gradient-to-r from-indigo-200 via-purple-200 to-indigo-300 bg-clip-text text-transparent leading-tight">
        Beautiful Avatars<br class="hidden sm:block"> Instantly.
      </h1>
      <p class="mt-6 text-lg md:text-xl text-slate-400 max-w-3xl mx-auto">Random, gender‑based or fixed — lightweight, deterministic and plug‑and‑play. Perfect for modern apps.</p>
    </div>

    <!-- four cards grid with improved microinteractions -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6 xl:gap-8 justify-items-center">
      <!-- 1 :: random card -->
      <div class="group relative w-full max-w-[280px] glow-card">
        <div class="absolute -inset-1 bg-gradient-to-r from-indigo-500/20 to-purple-500/20 rounded-3xl blur-xl opacity-0 group-hover:opacity-100 transition duration-700"></div>
        <div class="relative bg-gradient-to-br from-slate-800/90 to-slate-900/90 backdrop-blur-sm rounded-2xl p-5 border border-slate-700/50 hover:border-indigo-500/50 transition-all duration-300">
          <button onclick="refreshSpecific(this)" class="hero-avatar-refresh absolute top-2 right-2 z-20 bg-indigo-600/90 hover:bg-indigo-500 text-white p-2 rounded-xl opacity-0 group-hover:opacity-100 transition-all duration-300 shadow-lg hover:shadow-indigo-600/30 refresh-btn" title="fresh avatar">
            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/></svg>
          </button>
          <div class="relative mx-auto w-36 h-36 md:w-40 md:h-40">
            <div class="absolute inset-0 rounded-full bg-gradient-to-r from-indigo-500 via-purple-500 to-pink-500 animate-spin-slow blur-md opacity-70 group-hover:opacity-100"></div>
            <div class="absolute inset-1 rounded-full bg-slate-900"></div>
            <div class="absolute inset-2 rounded-full overflow-hidden ring-2 ring-white/10 group-hover:ring-indigo-500/50 transition-all">
              <img src="/api/avatars?t=<%= Date.now() %>" data-base="/api/avatars" alt="random" class="w-full h-full object-cover transition duration-700 group-hover:scale-110 group-hover:rotate-3">
            </div>
            <span class="absolute bottom-1 right-1 w-3.5 h-3.5 bg-indigo-400 rounded-full border-2 border-slate-900 animate-pulse"></span>
          </div>
          <div class="mt-5 text-center">
            <h3 class="text-sm font-semibold text-indigo-400">Random</h3>
            <div class="mt-2 font-mono text-xs bg-slate-800/80 p-2 rounded-lg border border-slate-700 group-hover:border-indigo-500/30">
              <code class="text-indigo-300">/api/avatars</code>
              <div class="text-slate-400 text-[10px] mt-1 flex justify-center items-center gap-1"><span class="w-1.5 h-1.5 bg-indigo-400 rounded-full animate-pulse"></span> Any Gender</div>
            </div>
          </div>
        </div>
      </div>

      <!-- 2 :: male card -->
      <div class="group relative w-full max-w-[280px] glow-card">
        <div class="absolute -inset-1 bg-gradient-to-r from-blue-500/20 to-cyan-500/20 rounded-3xl blur-xl opacity-0 group-hover:opacity-100"></div>
        <div class="relative bg-gradient-to-br from-slate-800/90 to-slate-900/90 rounded-2xl p-5 border border-slate-700/50 hover:border-blue-500/50">
          <button onclick="refreshSpecific(this)" class="hero-avatar-refresh absolute top-2 right-2 z-20 bg-blue-600/90 hover:bg-blue-500 text-white p-2 rounded-xl opacity-0 group-hover:opacity-100 refresh-btn">
            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/></svg>
          </button>
          <div class="relative mx-auto w-36 h-36 md:w-40 md:h-40">
            <div class="absolute inset-0 rounded-full bg-gradient-to-r from-blue-500 via-cyan-500 to-teal-500 animate-pulse-slow blur-md opacity-75"></div>
            <div class="absolute inset-1 rounded-full bg-slate-900"></div>
            <div class="absolute inset-2 rounded-full overflow-hidden ring-2 ring-white/10 group-hover:ring-blue-500/50">
              <img src="/api/avatars?gender=boy&t=<%= Date.now() %>" data-base="/api/avatars?gender=boy" alt="male" class="w-full h-full object-cover transition group-hover:scale-110 group-hover:-rotate-3">
            </div>
            <span class="absolute -bottom-1 -right-1 w-6 h-6 bg-blue-500 rounded-full flex items-center justify-center text-white text-xs border-2 border-slate-900 gender-badge">♂</span>
          </div>
          <div class="mt-5 text-center">
            <h3 class="text-sm font-semibold text-blue-400">Male</h3>
            <div class="mt-2 font-mono text-xs bg-slate-800/80 p-2 rounded-lg border border-slate-700 group-hover:border-blue-500/30">
              <code class="text-blue-300">/api/avatars?gender=boy</code>
              <div class="text-slate-400 text-[10px] mt-1 flex justify-center items-center gap-1"><span class="w-1.5 h-1.5 bg-blue-400 rounded-full animate-pulse"></span> Filters Male Avatars</div>
            </div>
          </div>
        </div>
      </div>

      <!-- 3 :: female card -->
      <div class="group relative w-full max-w-[280px] glow-card">
        <div class="absolute -inset-1 bg-gradient-to-r from-pink-500/20 to-rose-500/20 rounded-3xl blur-xl opacity-0 group-hover:opacity-100"></div>
        <div class="relative bg-gradient-to-br from-slate-800/90 to-slate-900/90 rounded-2xl p-5 border border-slate-700/50 hover:border-pink-500/50">
          <button onclick="refreshSpecific(this)" class="hero-avatar-refresh absolute top-2 right-2 z-20 bg-pink-600/90 hover:bg-pink-500 text-white p-2 rounded-xl opacity-0 group-hover:opacity-100 refresh-btn">
            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/></svg>
          </button>
          <div class="relative mx-auto w-36 h-36 md:w-40 md:h-40">
            <div class="absolute inset-0 rounded-full bg-gradient-to-r from-pink-500 via-rose-500 to-red-500 animate-pulse-slow blur-md opacity-75"></div>
            <div class="absolute inset-1 rounded-full bg-slate-900"></div>
            <div class="absolute inset-2 rounded-full overflow-hidden ring-2 ring-white/10 group-hover:ring-pink-500/50">
              <img src="/api/avatars?gender=girl&t=<%= Date.now() %>" data-base="/api/avatars?gender=girl" alt="female" class="w-full h-full object-cover transition group-hover:scale-110 group-hover:rotate-3">
            </div>
            <span class="absolute -bottom-1 -right-1 w-6 h-6 bg-pink-500 rounded-full flex items-center justify-center text-white text-xs border-2 border-slate-900 gender-badge">♀</span>
          </div>
          <div class="mt-5 text-center">
            <h3 class="text-sm font-semibold text-pink-400">Female</h3>
            <div class="mt-2 font-mono text-xs bg-slate-800/80 p-2 rounded-lg border border-slate-700 group-hover:border-pink-500/30">
              <code class="text-pink-300">/api/avatars?gender=girl</code>
              <div class="text-slate-400 text-[10px] mt-1 flex justify-center items-center gap-1"><span class="w-1.5 h-1.5 bg-pink-400 rounded-full animate-pulse"></span> Filters Female Avatars</div>
            </div>
          </div>
        </div>
      </div>

      <!-- 4 :: deterministic / ID card -->
      <div class="group relative w-full max-w-[280px] glow-card">
  <div class="absolute -inset-1 bg-gradient-to-r from-amber-500/20 to-orange-500/20 rounded-3xl blur-xl opacity-0 group-hover:opacity-100"></div>
  <div class="relative bg-gradient-to-br from-slate-800/90 to-slate-900/90 rounded-2xl p-5 border border-slate-700/50 hover:border-amber-500/50">
    <button onclick="refreshSpecific(this)" class="hero-avatar-refresh absolute top-2 right-2 z-20 bg-amber-600/90 hover:bg-amber-500 text-white p-2 rounded-xl opacity-0 group-hover:opacity-100 refresh-btn">
      <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/></svg>
    </button>
    <div class="relative mx-auto w-36 h-36 md:w-40 md:h-40">
      <div class="absolute inset-0 rounded-full bg-gradient-to-r from-amber-500 via-orange-500 to-yellow-500 animate-pulse-slow blur-md opacity-75"></div>
      <div class="absolute inset-1 rounded-full bg-slate-900"></div>
      <div class="absolute inset-2 rounded-full overflow-hidden ring-2 ring-white/10 group-hover:ring-amber-500/50">
        <img 
          id="deterministic-avatar"
          src="/api/avatars/42?t=<%= Date.now() %>" 
          data-base="/api/avatars/" 
          alt="fixed" 
          class="w-full h-full object-cover transition group-hover:scale-110 group-hover:-rotate-3"
        >
      </div>
      <span class="absolute -bottom-1 -right-1 w-6 h-6 bg-amber-500 rounded-full flex items-center justify-center text-white text-[10px] font-bold border-2 border-slate-900">#</span>
    </div>
    <div class="mt-5 text-center">
      <h3 class="text-sm font-semibold text-amber-400">Deterministic</h3>
      
      <!-- ID Input Field -->
      <div class="mt-3 flex items-center justify-center gap-2">
        <input 
          type="text" 
          id="avatar-id-input"
          value="42"
          class="w-20 px-2 py-1.5 text-sm bg-slate-800/80 border border-slate-600 rounded-lg text-amber-300 font-mono text-center focus:outline-none focus:ring-2 focus:ring-amber-500/50 focus:border-amber-500 transition-all"
          placeholder="ID"
          onkeypress="handleIdInputKeyPress(event)"
        >
        <button 
          onclick="generateDeterministicAvatar()"
          class="px-3 py-1.5 bg-amber-600/80 hover:bg-amber-600 text-white text-xs rounded-lg transition-all hover:scale-105 font-medium shadow-lg shadow-amber-900/30 flex items-center gap-1"
        >
          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
          </svg>
          Generate
        </button>
      </div>
      
      <div class="mt-2 font-mono text-xs bg-slate-800/80 p-2 rounded-lg border border-slate-700 group-hover:border-amber-500/30">
        <code class="text-amber-300" id="current-id-url">/api/avatars/[ID]</code>
        <div class="text-slate-400 text-[10px] mt-1 flex justify-center items-center gap-1"><span class="w-1.5 h-1.5 bg-orange-400 rounded-full animate-pulse"></span> Enter Any ID And Generate</div>
      </div>
    </div>
  </div>
</div>
    </div>

    <!-- CTA button after cards -->
    <div class="text-center mt-16">
      <a href="#get-started" class="inline-flex items-center gap-3 px-10 py-5 bg-gradient-to-r from-indigo-600 to-purple-600 hover:from-indigo-500 hover:to-purple-500 text-white font-semibold text-xl rounded-2xl shadow-2xl shadow-indigo-900/50 hover:shadow-indigo-700/60 transform hover:-translate-y-1 transition-all duration-300">
        <span>⚡ Start building</span> <span>→</span>
      </a>
    </div>
  </div>
</section>

<!-- ========== FEATURES / GET STARTED (improved) ========== -->
<section id="get-started" class="py-20 md:py-28 relative overflow-hidden bg-gradient-to-b from-slate-950 via-indigo-950/20 to-slate-950">
  <!-- animated background orbs -->
  <div class="absolute top-20 left-10 w-72 h-72 bg-indigo-600/10 rounded-full blur-3xl animate-pulse"></div>
  <div class="absolute bottom-20 right-10 w-80 h-80 bg-purple-600/10 rounded-full blur-3xl animate-pulse animation-delay-2000"></div>

  <div class="max-w-7xl mx-auto px-5 relative">
    <div class="text-center mb-16">
      <h2 class="text-4xl md:text-5xl font-bold"><span class="bg-gradient-to-r from-indigo-200 to-purple-200 bg-clip-text text-transparent">Simple · Fast · Consistent</span></h2>
      <p class="text-slate-400 text-lg mt-4 max-w-2xl mx-auto">Three ways to generate, one easy API. Copy the snippet and you’re done.</p>
    </div>

    <!-- 3 feature columns with live preview & copy -->
    <div class="grid md:grid-cols-3 gap-7 lg:gap-8">
      <!-- card 1: random -->
      <div class="bg-slate-800/40 backdrop-blur-sm rounded-2xl p-6 border border-slate-700/60 hover:border-indigo-500/50 transition-all group">
        <div class="flex items-center gap-4 mb-5">
          <span class="text-4xl bg-indigo-500/20 p-3 rounded-2xl">🎲</span>
          <h3 class="text-xl font-semibold text-indigo-300">Random</h3>
        </div>
        <p class="text-slate-400 text-sm mb-5">Unopinionated, unpredictable — great for testing or anonymous profiles.</p>
        <div class="bg-slate-950/80 rounded-xl p-3 border border-slate-700 relative">
          <div class="flex justify-between items-center text-xs text-indigo-400 mb-2"><span>GET /api/avatars</span>
            <button onclick="copyToClipboard('/api/avatars')" class="text-slate-400 hover:text-indigo-400 code-copy-btn" title="copy url"><svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z"/></svg></button>
          </div>
          <code class="block text-sm text-green-300">&lt;img src=<span class="text-yellow-300">"/api/avatars"</span> /&gt;</code>
        </div>
        <div class="mt-6 flex justify-center">
          <img src="/api/avatars?t=<%= Date.now() %>" class="w-16 h-16 rounded-full ring-2 ring-indigo-500/30 group-hover:scale-110 transition-transform" alt="random preview">
        </div>
      </div>

      <!-- card 2: gender filter -->
      <div class="bg-slate-800/40 backdrop-blur-sm rounded-2xl p-6 border border-slate-700/60 hover:border-blue-500/50 transition-all group">
        <div class="flex items-center gap-4 mb-5">
          <span class="text-4xl bg-blue-500/20 p-3 rounded-2xl">👥</span>
          <h3 class="text-xl font-semibold text-blue-300">Gender Filter</h3>
        </div>
        <p class="text-slate-400 text-sm mb-10">Boy or Girl — fine‑tune your avatars with a query.</p>
        <div class="bg-slate-950/80 rounded-xl p-3 border border-slate-700">
          <div class="flex justify-between items-center text-xs text-blue-400 mb-2"><span>GET /api/avatars?gender=boy</span>
            <button onclick="copyToClipboard('/api/avatars?gender=boy')" class="text-slate-400 hover:text-blue-400 code-copy-btn"><svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z"/></svg></button>
          </div>
          <code class="block text-sm text-green-300">&lt;img src=<span class="text-yellow-300">"/api/avatars?gender=boy"</span> /&gt;</code>
        </div>
        <div class="mt-6 flex justify-center gap-3">
          <img src="/api/avatars?gender=boy&t=<%= Date.now() %>" class="w-14 h-14 rounded-full ring-2 ring-blue-500/30 hover:scale-110 transition" alt="boy">
          <img src="/api/avatars?gender=girl&t=<%= Date.now() %>" class="w-14 h-14 rounded-full ring-2 ring-pink-500/30 hover:scale-110 transition" alt="girl">
        </div>
      </div>

      <!-- card 3: deterministic ID -->
      <div class="bg-slate-800/40 backdrop-blur-sm rounded-2xl p-6 border border-slate-700/60 hover:border-amber-500/50 transition-all group">
